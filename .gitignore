# Git Ignore Configuration
# Specifies intentionally untracked files that Git should ignore

# ───────────────────────────────────────────
# CRITICAL: Override global gitignore
# ───────────────────────────────────────────
# The global ~/.gitignore_global ignores /.opencode/ for symlinked repos.
# But THIS repo is the SOURCE of .opencode/ content - it MUST be tracked.
# The negation pattern below overrides the global ignore.
!.opencode/
!specs

# API keys and secrets
# ───────────────────────────────────────────
*.key
*.pem

# Archive
# ───────────────────────────────────────────
/z — Archive/
.opencode/agent/.provider-backups/


# Build output
# ───────────────────────────────────────────
dist/
.opencode/output/

# Certificates
# ───────────────────────────────────────────
*.cert

# Database files
# ───────────────────────────────────────────
*.db
*.sqlite3
.opencode/skill/system-spec-kit/mcp_server/database/*.sqlite
.opencode/skill/system-spec-kit/mcp_server/database/*.sqlite-shm
.opencode/skill/system-spec-kit/mcp_server/database/*.sqlite-wal
.opencode/skill/system-spec-kit/mcp_server/database/*.sqlite.bak*
.opencode/skill/system-spec-kit/mcp_server/database/.db-updated

# Dependencies
# ───────────────────────────────────────────
**/node_modules
node_modules/

# Environment files
# ───────────────────────────────────────────
.env
.env.*
.env.*.local
.env.local

# Local settings
# ───────────────────────────────────────────
*.local
settings.local.json

# Log files
# ───────────────────────────────────────────
*.log

# OS generated files
# ───────────────────────────────────────────
.DS_Store

# Python
# ───────────────────────────────────────────
__pycache__/

# Project-specific commands (not part of framework)
# ───────────────────────────────────────────
.opencode/command/agent_router.md
.claude/commands/agent_router.md
.agents/commands/agent_router.md

# Temporary files
# ───────────────────────────────────────────
tmp/
.tmp/
**/vitest-tmp/
**/node-compile-cache/

# Non-dev AI systems specs (project-specific, not framework)
# ───────────────────────────────────────────
.opencode/specs/00--ai-systems-non-dev

.opencode/skill/system-spec-kit/mcp_server/database/speckit-eval.db-wal

.opencode/skill/system-spec-kit/mcp_server/database/speckit-eval.db-shm

# Local symlinked repos
# ───────────────────────────────────────────
/anobel.com

# CocoIndex Code semantic index
# ───────────────────────────────────────────
.cocoindex_code/

# CocoIndex Code MCP skill venv
# ───────────────────────────────────────────
.opencode/skill/mcp-cocoindex-code/mcp_server/.venv/
.opencode/skill/mcp-coco-index/mcp_server/.venv/
