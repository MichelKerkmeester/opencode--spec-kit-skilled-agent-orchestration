  "validation_rules": {
    "h2_pattern": "^## (\\d+)\\.\\s+(.+)$",
    "h2_with_emoji_pattern": "^## (\\d+)\\.\\s+([^\\w\\s])\\s+(.+)$",
    "toc_header": "## TABLE OF CONTENTS",
    "toc_entry_pattern": "^- \\[(.+?)\\]\\(#(.+?)\\)$",
    "toc_anchor_double_dash_pattern": "^(\\d+)--([a-z_-]+)$",
    "section_separator": "---"
  },
  "severity_definitions": {
    "blocking": {
      "description": "Errors that must be fixed before document is considered valid",
      "exit_code": 1,
      "errors": [
        "h2_not_uppercase",
        "toc_single_dash_anchor",
        "toc_not_uppercase",
        "missing_toc",
        "missing_required_section"
      ]
    },
    "warning": {
      "description": "Issues that should be addressed but don't block validation",
      "exit_code": 0,
      "errors": [
        "non_sequential_numbering",
        "missing_recommended_section",
        "toc_entry_mismatch"
      ]
    },
    "info": {
      "description": "Informational notes that may indicate style inconsistencies",
      "exit_code": 0,
      "errors": [
        "extra_section",
        "unusual_section_order"
      ]
    }
  },
  "auto_fix_rules": {
    "toc_single_dash_to_double": {
      "description": "Convert single-dash TOC anchors to double-dash",
      "safe": true,
      "pattern": "#(\\d+)-([a-z])",
      "replacement": "#$1--$2"
    },
    "uppercase_h2_section": {
      "description": "Convert H2 section name to ALL CAPS",
      "safe": true
    },
    "uppercase_toc_entry": {
      "description": "Convert TOC entry section name to ALL CAPS",
      "safe": true
    }
  }
}
