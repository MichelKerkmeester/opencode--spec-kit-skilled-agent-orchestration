e/skill/cli-opencode/manual_testing_playbook/06--integration-patterns/001-cross-ai-handback-codex.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/05--session-continuity/003-fork-and-share.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/05--session-continuity/002-resume-by-session-id.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/05--session-continuity/001-continue-last-session.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/04--agent-routing/005-ultra-think-multi-strategy.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/04--agent-routing/004-write-agent-doc-generation.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/04--agent-routing/003-review-agent-security-audit.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/04--agent-routing/002-context-leaf-agent.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/04--agent-routing/001-general-agent-default.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/03--multi-provider/004-variant-levels-comparison.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/03--multi-provider/003-google-gemini-2-5-pro.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/03--multi-provider/002-openai-gpt-5-5.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/03--multi-provider/001-opencode-go-default-deepseek.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/02--external-dispatch/002-from-codex-handback.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/01--cli-invocation/005-pure-and-print-logs.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/01--cli-invocation/004-file-attachment-via-f-flag.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/01--cli-invocation/002-format-default-vs-json.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/01--cli-invocation/001-base-non-interactive-invocation.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/manual_testing_playbook/02--external-dispatch/001-from-claude-code.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/SKILL.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/README.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/assets/prompt_templates.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/references/agent_delegation.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/references/integration_patterns.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/references/opencode_tools.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skill/cli-opencode/references/cli_reference.md\n/Use